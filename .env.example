# ============================================================================
# Story Pointer — environment configuration
# Copy this file to ".env" and fill in the values you need.
# Everything has a sensible default EXCEPT the provider key for your chosen
# provider. Only ONE provider block needs to be configured.
# ============================================================================

# ----------------------------------------------------------------------------
# 1. Provider selection
# ----------------------------------------------------------------------------
# Which LLM backend to use for estimation. One of: groq | openai | claude | glm
LLM_PROVIDER=openai

# Which DSL graph to run.
#   http  -> graph_http.yml  (http-request nodes; ZERO external binaries;
#                             calls any OpenAI-compatible / Anthropic endpoint)
#   slim  -> graph_slim.yml  (native graphon `llm` nodes; requires the
#                             `dify-plugin-daemon-slim` binary + Dify plugins)
LLM_EXECUTION_MODE=http

# ----------------------------------------------------------------------------
# 2. Model identifiers (defaults match each provider; override as needed)
# ----------------------------------------------------------------------------
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o-mini
CLAUDE_MODEL=claude-3-5-sonnet-20241022
GLM_MODEL=glm-4-flash

# Generation params passed to the model
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2400
# HTTP 429 handling. The provider's Retry-After / "try again in" duration wins
# when it is longer. Set retries to 0 to fail immediately without holding.
LLM_RATE_LIMIT_WAIT_SECONDS=15
LLM_RATE_LIMIT_MAX_RETRIES=3

# ----------------------------------------------------------------------------
# 3. Provider credentials  (set the one matching LLM_PROVIDER)
# ----------------------------------------------------------------------------
# Groq  — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenAI — https://platform.openai.com/api-keys  (set OPENAI_BASE_URL for proxies/Azure-style)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION=

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_VERSION=2023-06-01

# Zhipu GLM — https://open.bigmodel.cn/  (OpenAI-compatible)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ----------------------------------------------------------------------------
# 4. Graphon / Slim (only needed when LLM_EXECUTION_MODE=slim)
# ----------------------------------------------------------------------------
SLIM_MODE=local
SLIM_PLUGIN_FOLDER=.slim/plugins
SLIM_BINARY_PATH=
SLIM_DAEMON_ADDR=
SLIM_DAEMON_KEY=
SLIM_MARKETPLACE_URL=https://marketplace.dify.ai

# ----------------------------------------------------------------------------
# 5. Jira integration (multi-instance)
# ----------------------------------------------------------------------------
# JSON array. Each entry:
#   { "name": "...", "base_url": "...", "version": "v3"|"v2",
#     "auth_type": "pat"|"basic",
#     "token": "<cloud PAT>" | "username": "...", "password": "...",
#     "email": "<cloud account email, optional>" }
# version "v3" = Jira Cloud REST API v3; "v2" = Jira Server / Data Center.
# Example:
# JIRA_INSTANCES=[{"name":"prod","base_url":"https://acme.atlassian.net","version":"v3","auth_type":"pat","email":"po@acme.com","token":"ATATT..."}]
JIRA_INSTANCES=

# ----------------------------------------------------------------------------
# 6. Server
# ----------------------------------------------------------------------------
HOST=127.0.0.1
PORT=8000
# Comma-separated list of allowed CORS origins. "*" allows all.
CORS_ORIGINS=*

# ----------------------------------------------------------------------------
# 7. OpenTelemetry / Arize Phoenix monitoring
# ----------------------------------------------------------------------------
# Start the local collector/UI with: phoenix serve
# Or start Phoenix and this app together with: python run.py --with-phoenix
PHOENIX_ENABLED=true
PHOENIX_COLLECTOR_ENDPOINT=http://127.0.0.1:6006/v1/traces
PHOENIX_UI_URL=http://127.0.0.1:6006
PHOENIX_PROJECT_NAME=story-pointer
# Only needed for authenticated Phoenix deployments / Phoenix Cloud.
PHOENIX_API_KEY=
# Batch export is recommended outside tests.
PHOENIX_BATCH=true
# Privacy-safe default: do not export story text, prompts, or model output.
PHOENIX_CAPTURE_CONTENT=false
# Persistent local database/storage used by `phoenix serve`.
PHOENIX_WORKING_DIR=.phoenix
